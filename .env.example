# Local development: copy this file to ".env"
# Railway: add these keys under Variables

# Web
VITE_API_BASE_URL=http://localhost:8080

# API
PORT=8080
NODE_ENV=production

# Add your secrets below (keep empty here)
# JWT_SECRET=
# DATABASE_URL=

# Copy to ".env" for local development.
# In Railway, set these as Variables in the service settings.

# App
PORT=3000
NODE_ENV=production

# Database (optional; set if your app uses a DB)
DATABASE_URL=

# Add your project-specific keys below, e.g.
# JWT_SECRET=
# SUPABASE_URL=
# SUPABASE_ANON_KEY=

